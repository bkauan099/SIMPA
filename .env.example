# ════════════════════════════════════════════════════════
# CONFIGURAÇÃO DE E-MAIL — SIMPA
# ════════════════════════════════════════════════════════
#
# OPÇÃO 1: Gmail
#   1. Acesse: https://myaccount.google.com/apppasswords
#   2. Gere uma "Senha de app" para "Outro aplicativo"
#   3. Use essa senha de 16 caracteres em SMTP_PASS
#
# OPÇÃO 2: Mailtrap (testes sem enviar e-mail real)
#   Cadastre em https://mailtrap.io e copie as credenciais
#
# OPÇÃO 3: Outlook / Hotmail
#   SMTP_HOST = smtp-mail.outlook.com
#   SMTP_PORT = 587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_aqui
SMTP_FROM=seuemail@gmail.com
SMTP_NAME=SIMPA - UEMA ProExae
