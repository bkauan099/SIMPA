# ============================================================
# SIMPA — Regras de Segurança e Redirecionamento
# ============================================================

Options -Indexes

# Bloquear acesso direto a pastas sensíveis via URL
RewriteEngine On

# Redirecionar raiz para login se não autenticado
RewriteRule ^$ index.php [L]

# ── URLs limpas (sem extensão .php) ──────────────────────────
# 1. Redireciona GET /pagina.php → /pagina  (não afeta POST/AJAX)
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2. Reescreve /pagina → /pagina.php internamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# Bloquear acesso direto a .env, logs, lib, model, views, conexao
# (controllers NÃO é bloqueado aqui pois é chamado via fetch/AJAX pelo front-end)
RewriteRule ^\.env$              - [F,L]
RewriteRule ^logs/               - [F,L]
RewriteRule ^lib/                - [F,L]
RewriteRule ^model/              - [F,L]
RewriteRule ^views/              - [F,L]
RewriteRule ^conexao/            - [F,L]

# Bloquear acesso a arquivos de configuração e backup
<FilesMatch "\.(env|log|sql|bak|sh|git|md|json|lock)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Bloquear composer files
<FilesMatch "^(composer\.(json|lock)|package\.json)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Headers de segurança
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
